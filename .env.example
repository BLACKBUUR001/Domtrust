# ============================================================
# DomTrust — Variables d'environnement
# Copier ce fichier en .env puis remplir les valeurs réelles.
# ⚠️ Ne jamais commiter le fichier .env (déjà dans .gitignore)
# ============================================================

# --- Base de données PostgreSQL (Neon / autre) ---
DATABASE_URL=postgresql://user:password@host/dbname?sslmode=require

# --- Envoi d'email (Gmail App Password recommandé) ---
# Générer un App Password : https://myaccount.google.com/apppasswords
EMAIL_USER=votre-adresse@gmail.com
EMAIL_PASS=your_16_char_app_password
EMAIL_TO=destinataire@gmail.com

# --- Serveur Express (dev local uniquement) ---
PORT=3001

# --- CORS : domaine(s) autorisé(s) en production (séparer par virgule) ---
# Laisser vide en dev (les origines localhost sont autorisées par défaut)
CORS_ORIGIN=https://domtrust.vercel.app

# --- Frontend ---
# URL de base de l'API. Laisser vide en prod pour utiliser le même domaine (/api).
# En dev : http://localhost:3001
VITE_API_URL=
